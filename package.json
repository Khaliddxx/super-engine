{
  "name": "super-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Phone-first automated cold outreach engine: find leads, redesign their sites with AI, send via LinkedIn, triage replies",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:orchestrator": "pnpm --filter @super-engine/orchestrator dev",
    "dev:pwa": "pnpm --filter @super-engine/pwa dev",
    "db:generate": "pnpm --filter @super-engine/db generate",
    "db:migrate": "pnpm --filter @super-engine/db migrate",
    "db:seed": "pnpm --filter @super-engine/orchestrator seed",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "prettier": "^3.4.2"
  }
}
