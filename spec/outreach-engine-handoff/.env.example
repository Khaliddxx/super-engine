# ==============================================================================
# Outreach Engine — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.
# ==============================================================================

# --- PHASE 1: Offline pipeline (scrape → qualify → redesign → deploy) ---

# Anthropic API (all Claude calls: qualify, redesign, triage, drafting)
# Get from: https://console.anthropic.com/settings/keys
# Starts with sk-ant-
ANTHROPIC_API_KEY=

# Google Places API (lead scraping)
# Get from: https://console.cloud.google.com/ → enable "Places API (New)" → credentials
# Required: billing account attached. Free tier = $200/mo credit ≈ 11k lookups.
PLACES_API_KEY=

# Firecrawl (site content scraping for enrichment)
# Get from: https://www.firecrawl.dev/ → dashboard
# Starts with fc-
FIRECRAWL_API_KEY=

# Vercel (deploy redesigned previews)
# Token: https://vercel.com/account/tokens
# Team ID: found in your team's settings URL (team_xxxxx)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Supabase (Postgres)
# Get from: your project → Settings → Database → Connection string (use "Transaction pooler")
# Format: postgresql://postgres.xxx:PASSWORD@aws-xxx.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Redis (BullMQ queues)
# Upstash: https://upstash.com → create DB → copy REDIS_URL
# Railway alt: add Redis addon to your project
REDIS_URL=


# --- PHASE 2: Email sending ---

# Hunter.io (email enrichment)
# Get from: https://hunter.io/api-keys
HUNTER_API_KEY=

# Instantly (email sending + warmup + deliverability)
# Get from: https://app.instantly.ai/app/settings/integrations
# CAMPAIGN_ID is for the outreach campaign you set up inside Instantly
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=

# JWT secret for the approval PWA
# Generate with: openssl rand -base64 32
JWT_SECRET=


# --- PHASE 4: LinkedIn ---

# Unipile (LinkedIn messaging via their proxy)
# Get from: https://app.unipile.com → settings → API
# ACCOUNT_ID is the LinkedIn account you've connected inside Unipile
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=


# --- OPTIONAL: Operator notifications ---

# Slack webhook (recommended — instant push to phone if you have Slack)
# Create at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=

# OR Expo push token (if using a custom mobile app for notifications)
EXPO_PUSH_TOKEN=


# --- OPTIONAL: Imagery strategy (Phase 6+) ---

# Pexels (free stock imagery API)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=

# Gemini (for AI-generated imagery, "generated" imagery strategy)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=


# --- OPERATOR CONFIG ---

OPERATOR_EMAIL=you@example.com
OPERATOR_TIMEZONE=Europe/Amsterdam
NODE_ENV=development
PORT=3000
