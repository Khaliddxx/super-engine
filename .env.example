# ─────────────────────────────────────────────
#  Super Engine — environment variables
# ─────────────────────────────────────────────
# Copy to .env and fill. Keep secrets out of git.

# ── Runtime ─────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ── Operator identity (goes into redesign contact block) ──
OPERATOR_NAME="Your Name"
OPERATOR_EMAIL=""
OPERATOR_PHONE=""

# ── Auth (single-operator PWA) ──
JWT_SECRET=""
OPERATOR_PASSWORD=""

# ── Database (Supabase) ──
DATABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# ── Queue (Upstash Redis) ──
REDIS_URL=""

# ── LLM ──
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-5-20250929"

# ── Lead sourcing ──
GOOGLE_PLACES_API_KEY=""

# ── Enrichment ──
HUNTER_API_KEY=""
FIRECRAWL_API_KEY=""

# ── Deployment (redesign previews) ──
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# ── Outreach (LinkedIn via Unipile) ──
UNIPILE_API_KEY=""
UNIPILE_DSN=""
UNIPILE_ACCOUNT_ID=""
LINKEDIN_DAILY_CAP=10

# ── Outreach (Email — deferred, warmup running) ──
INSTANTLY_API_KEY=""

# ── Notifications ──
SLACK_WEBHOOK_URL=""

# ── Railway (orchestrator) ──
RAILWAY_PROJECT_ID=""
RAILWAY_API_TOKEN=""

# ── PWA → API base URL (prod: your Railway URL, dev: http://localhost:3001) ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
